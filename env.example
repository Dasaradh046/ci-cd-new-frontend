# ===========================================
# DevSecOps Platform Environment Configuration
# ===========================================

# Application
NODE_ENV=development
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# Authentication
NEXTAUTH_SECRET=your-nextauth-secret-min-32-chars-here
NEXTAUTH_URL=http://localhost:3000

# JWT RS256 Configuration
# Path to RSA public key for JWT verification (relative to project root)
RS256_PUBLIC_KEY_PATH=./keys/public.pem

# Token Configuration
JWT_ACCESS_TOKEN_EXPIRY=15m
JWT_REFRESH_TOKEN_EXPIGY=7d

# API Configuration
REFRESH_ENDPOINT=/api/auth/refresh

# Database (if using external database)
DATABASE_URL=postgresql://devsecops:devsecops@localhost:5432/devsecops

# Redis (for session caching)
REDIS_URL=redis://localhost:6379

# Security
# Encryption key for PII (32 bytes, base64 encoded)
ENCRYPTION_KEY=your-encryption-key-here

# CORS
CORS_ORIGIN=http://localhost:3000

# Logging
LOG_LEVEL=debug

# Feature Flags
ENABLE_MOCK_DATA=true
ENABLE_2FA=true
